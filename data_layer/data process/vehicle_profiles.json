{
  "_README": {
    "说明": "各机型告警临界值配置。合并优先级：_default < _classes[该机型的class] < 机型自身字段。",
    "机型代号来源": "键名必须是游戏 indicators 的 type 字段（实测最可靠）。注意：它【不一定等于】datamine 文件名——例如实测 type 'hs-123a-1_china'(连字符+国家后缀) 对应 datamine 文件名却是 'hs_123a_1'，两套命名规则不统一。大量代号两者恰好一致(如 j_15t/a6m2_zero/bf-109f-4)，故未实测的机型以 datamine 名作尽力填充；若某机进战局后 profile_matched=false，请以 /api/processed 里的真实 vehicle_type 为准修正。",
    "性能数值来源": "重要：游戏不存储静态的‘失速速度/临界攻角/结构限速’，均由实时物理计算。因此本表的 stall/aoa/altitude/overspeed 阈值是按【飞机类别】给出的工程估算（参考真实航空性能），不是游戏精确数值，请按需微调。overspeed(never-exceed)各机撕裂线差异很大。modern_jet 已用 j_15t 真机断翼校准：实测 ~1609 km/h IAS 断翼，本类 crit 1500 在断翼前约 96km/h/3.6s 触发，窗口合理；其余类别仍为保守估值，待逐类真机抓‘俯冲到撕裂’校准。注意：断翼在遥测里无直接信号(无 hudmsg、/state 无结构损坏字段)，只能靠 IAS 阈值【预测式预警】，无法事后检出撕裂瞬间。",
    "如何确认自己机型的代号": "进入战局后访问 http://localhost:8112/api/processed，看 vehicle_type 字段；若该代号不在本表则回退 _default（profile_matched=false），可自行新增一条。",
    "加力时间说明": "afterburner_max_sec=0 表示不限/未知，不触发加力超时告警。喷气机在游戏内通常无加力时间限制；活塞机 WEP 的过热限制非固定秒数，故默认不计时，需要的话可自行按机型填写。",
    "字段含义": {
      "class": "引用 _classes 中的类别模板名",
      "_tested": "true 表示该机型代号(type)已在游戏内实机采样验证过，最可靠；无此标记的为按 datamine 名尽力填充",
      "fuel_time_warn_sec": "能估出油耗率时优先按剩余可飞时间告警：低于此秒数 -> 警告",
      "fuel_time_critical_sec": "剩余可飞时间低于此秒数 -> 危急",
      "fuel_low_fraction": "回退用：未估出油耗率(刚起飞)时，剩余燃油比例低于此 -> 警告(0~1)",
      "fuel_critical_fraction": "回退用：剩余燃油比例低于此 -> 危急(0~1)",
      "stall_warn_kmh": "IAS 低于此 -> 失速警告",
      "stall_critical_kmh": "IAS 低于此 -> 失速危急",
      "overspeed_warn_kmh": "IAS 高于此(km/h) -> 超速警告（结构限速 never-exceed）。游戏不存静态限速，本值按类别工程估算，需逐机校准",
      "overspeed_critical_kmh": "IAS 高于此(km/h) -> 超速危急（机体可能解体）。各机撕裂线不同，按机型微调",
      "overspeed_warn_mach": "【选填·多给喷气机】马赫高于此 -> 超速警告（跨音速压缩/失控）。与 IAS 判据取或；不填则只看 IAS",
      "overspeed_critical_mach": "【选填·多给喷气机】马赫高于此 -> 超速危急。与 IAS 判据取或",
      "aoa_warn_deg": "攻角高于此 -> 警告",
      "aoa_critical_deg": "攻角高于此 -> 危急",
      "altitude_warn_m": "海拔(MSL,非离地)低于此 -> 警告；null 关闭",
      "altitude_critical_m": "海拔低于此 -> 危急；null 关闭",
      "afterburner_throttle_threshold": "油门超过此值视为加力/WEP 开启",
      "afterburner_max_sec": "最大连续加力秒数；>0 超时告警，0=不报",
      "suppress_when_gear_down": "起落架放下时抑制失速/攻角/高度告警（避免起降误报）",
      "water_temp_warn_c": "【液冷机】水温高于此(℃) -> 过热警告；气冷机无水温字段自动不报",
      "water_temp_critical_c": "【液冷机】水温高于此(℃) -> 危急（即将损坏）。各机损坏线不同，多在115℃以上，按机型微调",
      "head_temp_warn_c": "【气冷机】缸头温度高于此(℃) -> 过热警告；液冷机一般无缸头字段自动不报。缸头温度量级约200~260℃",
      "head_temp_critical_c": "【气冷机】缸头温度高于此(℃) -> 危急（即将损坏），按机型微调",
      "turbine_temp_warn_c": "【喷气机】涡轮/排气温度高于此(℃) -> 过热警告。游戏把该值放在 water_temperature 键里(量级数百度)，数据层已识别为喷气并拆分，不会被活塞水温阈值误判",
      "turbine_temp_critical_c": "【喷气机】涡轮温度高于此(℃) -> 危急（即将损坏）。早期喷气满功率即可达700℃量级，按机型微调",
      "oil_temp_warn_c": "油温高于此(℃) -> 警告（液冷/气冷都有）",
      "oil_temp_critical_c": "油温高于此(℃) -> 危急。气冷机过热常以油温为主指标（约115℃开始损坏），实战中往往比缸头温度先到线",
      "proximity_warn_m": "我方空军时的敌军接近告警距离(米)：敌军首次进入此距离时报告一次（边沿触发）。空军对所有敌人用此距离；陆/海军的距离及是否对空告警见 _proximity。",
      "vrs_speed_kmh": "直升机涡环状态(VRS)判据：水平速度低于此(km/h)视为低速",
      "vrs_descent_ms": "直升机 VRS 警告：低速且下降率超过此(m/s)触发 vrs_warning",
      "vrs_descent_critical_ms": "直升机 VRS 危急：低速且下降率超过此(m/s)触发 vrs_critical"
    },
    "直升机说明": "直升机(army=air 但无 mach/gears、有 prop_rpm)单独归类 heli：禁用燃油/过载/加力/失速/攻角/高度告警（燃油几乎用不完、过载拉不大、可悬停）；仅保留涡环状态(VRS)告警——低速且明显垂直下降时旋翼失力。旋翼转速随机动大幅波动且与发动机绑定，不做转速告警，仅透传 rotor_rpm 供展示。",
    "接近告警说明": "map_obj 中敌军无唯一ID，跨帧通过位置最近邻+同图标关联识别同一单位；仅在敌军【从范围外进入范围内】或【在范围内新出现】时触发一次。规则随【我方兵种×敌方类型】变化：空军仅对空中敌人用机型 proximity_warn_m（螺旋桨/早期喷气2km、现代喷气5km）、对地面/海面单位不告警；陆军仅对地面敌人500m、对空中敌人不告警；海军仅对水面敌人2km、对空中敌人不告警。",
    "模糊家族识别说明": "_families 用于‘机型变体多、难逐一录入’的兜底：收到 vehicle_type 后先在表中精确匹配(profile_source=exact)，未命中且为空军时再按家族前缀做一次模糊识别(profile_source=family)，仍不中才回退 _default(profile_source=default)。同一家族(如 Fw 190 / Bf 109 各亚型)失速/超速/高度等阈值差异不大，按家族 class 套用即可。匹配方式：把 vehicle_type 去掉所有分隔符转小写(如 fw-190a-9->fw190a9)，与各家族 prefix(同样 compact)做‘开头匹配’，【最长前缀优先】(代码按长度降序，作者排列顺序无关)。最长优先用于消歧嵌套前缀：f4u(海盗,螺旋桨) 先于 f4(鬼怪,现代喷气)、ki100 先于 ki10、yak15(喷气) 先于 yak1(螺旋桨)。仅空军启用(家族阈值均为固定翼类别，避免误套到地/海载具)。新增家族：加一条 {prefix, label, class}，可选覆盖个别阈值字段；prefix 务必写完整的‘厂商+型号数字’(如 mig21 而非 mig2)以免误吞邻近型号。残留风险：未录入且型号数字是已录入较短家族数字超串的机型(如未录 ki100 时会落到 ki10)会被就近归类，属尽力而为，精确录入对应家族即可纠正。"
  },

